# Protegrity API Credentials (REQUIRED for protect-text command)
# Sign up at: https://www.protegrity.com/developers/dev-edition-api

# Your Protegrity account email
DEV_EDITION_EMAIL=your-email@company.com

# Your Protegrity account password
DEV_EDITION_PASSWORD=your-secure-password

# Your Protegrity API Key
DEV_EDITION_API_KEY=your-api-key-here

# Python dependency for Protect/Unprotect SDK path
# pip install protegrity-ai-developer-python

# Python version requirement
# python3 --version  # should be 3.11+

# Optional: Override endpoint URLs (uses config.json defaults if not set)
# PROTEGRITY_CLASSIFICATION_ENDPOINT=http://localhost:8580/pty/data-discovery/v2.0/classify
# PROTEGRITY_PROTECTION_ENDPOINT=http://localhost:8090/pty/data-protection/v1/protect
# PROTEGRITY_GUARDRAIL_ENDPOINT=http://localhost:8581/pty/semantic-guardrail/v1.1/conversations/messages/scan
# PROTEGRITY_ANONYMIZATION_ENDPOINT=http://localhost:8085/pty/anonymization/v3
# PROTEGRITY_SYNTHETIC_DATA_ENDPOINT=http://localhost:8095/pty/syntheticdata/v2
