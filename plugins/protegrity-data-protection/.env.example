# Protegrity API Credentials (REQUIRED for protect-text command)
# Sign up at: https://www.protegrity.com/developers/dev-edition-api

# Your Protegrity account email
DEV_EDITION_EMAIL=your-email@company.com

# Your Protegrity account password
DEV_EDITION_PASSWORD=your-secure-password

# Your Protegrity API Key
DEV_EDITION_API_KEY=your-api-key-here

# Optional: Override endpoint URLs for classification and guardrail Docker services
# (uses config.json defaults if not set)
# PROTEGRITY_CLASSIFICATION_ENDPOINT=http://localhost:8580/pty/data-discovery/v1.1/classify
# PROTEGRITY_GUARDRAIL_ENDPOINT=http://localhost:8581/pty/semantic-guardrail/v1.1/conversations/messages/scan
