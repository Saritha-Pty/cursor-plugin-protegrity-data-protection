# Protegrity API Credentials (REQUIRED for protect-text and unprotect-text commands)
# Sign up free at: https://www.protegrity.com/developers/dev-edition-api

# Your Protegrity account email
DEV_EDITION_EMAIL=your-email@company.com

# Your Protegrity account password
DEV_EDITION_PASSWORD=your-secure-password

# Your Protegrity API Key
DEV_EDITION_API_KEY=your-api-key-here

# ---------------------------------------------------------------------------
# Optional: Override default endpoint URLs
# (Uses config.json defaults if not set — edit config.json to change defaults)
# ---------------------------------------------------------------------------

# Data Discovery service (Analyze Sensitivity, Redact, Find & Redact, Find & Protect)
# PROTEGRITY_CLASSIFICATION_ENDPOINT=http://localhost:8580/pty/data-discovery/v2.0/classify

# Semantic Guardrail service (Scan Conversation Risk)
# PROTEGRITY_GUARDRAIL_ENDPOINT=http://localhost:8581/pty/semantic-guardrail/v1.1/conversations/messages/scan

# Synthetic Data service (Generate Synthetic Data)
# PROTEGRITY_SYNTHETIC_ENDPOINT=http://localhost:8095/pty/syntheticdata/v2

# Anonymization service (Anonymize Data)
# PROTEGRITY_ANONYMIZATION_ENDPOINT=http://localhost:8085/pty/anonymization/v3

# Audit log directory (default: .protegrity-logs in your project)
# PROTEGRITY_LOG_DIR=.protegrity-logs
