{
  "mcpServers": {
    "protegrity-data-discovery": {
      "command": "python",
      "args": ["-m", "protegrity_developer_python", "classify"],
      "env": {
        "PROTEGRITY_ENDPOINT": "http://localhost:8580/pty/data-discovery/v1.1/classify",
        "PROTEGRITY_LOG_LEVEL": "INFO"
      },
      "disabled": false
    },
    "protegrity-semantic-guardrail": {
      "command": "python",
      "args": ["-m", "protegrity_developer_python", "guardrail"],
      "env": {
        "PROTEGRITY_ENDPOINT": "http://localhost:8581/pty/semantic-guardrail/v1.1/conversations/messages/scan",
        "PROTEGRITY_LOG_LEVEL": "INFO"
      },
      "disabled": false
    },
    "protegrity-protection-api": {
      "command": "python",
      "args": ["-m", "protegrity_developer_python", "protect"],
      "env": {
        "PROTEGRITY_API_EMAIL": "${DEV_EDITION_EMAIL}",
        "PROTEGRITY_API_PASSWORD": "${DEV_EDITION_PASSWORD}",
        "PROTEGRITY_API_KEY": "${DEV_EDITION_API_KEY}",
        "PROTEGRITY_LOG_LEVEL": "INFO"
      },
      "disabled": false
    }
  }
}
