{
  "protegrity": {
    "version": "2.0.0",
    "classification_endpoint": "http://localhost:8580/pty/data-discovery/v2.0/classify",
    "redaction_endpoint": "http://localhost:8580/pty/data-discovery/v2.0/redact",
    "semantic_guardrail_endpoint": "http://localhost:8581/pty/semantic-guardrail/v1.1/conversations/messages/scan",
    "synthetic_data_endpoint": "http://localhost:8095/pty/syntheticdata/v2",
    "anonymization_endpoint": "http://localhost:8085/pty/anonymization/v3",
    "classification_score_threshold": 0.6,
    "enable_logging": true,
    "log_level": "INFO",
    "method": "redact",
    "masking_char": "#",
    "named_entity_map": {
      "PERSON": "PERSON",
      "LOCATION": "LOCATION",
      "EMAIL_ADDRESS": "EMAIL",
      "PHONE_NUMBER": "PHONE",
      "SOCIAL_SECURITY_ID": "SSN",
      "CREDIT_CARD_NUMBER": "CARD",
      "AGE": "AGE",
      "USERNAME": "USERNAME",
      "IP_ADDRESS": "IP",
      "ACCOUNT_NUMBER": "ACCOUNT",
      "PASSPORT_NUMBER": "PASSPORT",
      "DRIVER_LICENSE_NUMBER": "LICENSE",
      "DATE_OF_BIRTH": "DOB",
      "MEDICAL_RECORD": "MEDICAL",
      "BANK_ACCOUNT": "BANK"
    },
    "risk_thresholds": {
      "block": 0.9,
      "redact": 0.7,
      "warn": 0.5,
      "allow": 0.0
    },
    "audit": {
      "enabled": true,
      "log_directory": ".protegrity-logs",
      "retention_days": 90
    },
    "features": {
      "data_discovery": {
        "enabled": true,
        "requires_registration": false,
        "requires_docker": true,
        "service_port": 8580,
        "api_version": "2.0.0",
        "commands": ["analyze-data-sensitivity", "redact-sensitive-data", "find-and-redact", "find-and-protect"]
      },
      "data_protection": {
        "enabled": true,
        "requires_registration": true,
        "requires_docker": false,
        "sdk_package": "protegrity-ai-developer-python",
        "sdk_import": "appython",
        "commands": ["protect-text", "unprotect-text", "find-and-protect"]
      },
      "semantic_guardrail": {
        "enabled": true,
        "requires_registration": false,
        "requires_docker": true,
        "service_port": 8581,
        "api_version": "1.1.1",
        "commands": ["scan-conversation-risk"]
      },
      "synthetic_data": {
        "enabled": true,
        "requires_registration": false,
        "requires_docker": true,
        "service_port": 8095,
        "api_version": "2.0.0",
        "commands": ["generate-synthetic-data"]
      },
      "anonymization": {
        "enabled": true,
        "requires_registration": false,
        "requires_docker": true,
        "service_port": 8085,
        "api_version": "3.0.0",
        "commands": ["anonymize-data"]
      }
    }
  }
}
